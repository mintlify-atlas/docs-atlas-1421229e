  "publicApiSurface": [
    "agent_v0.py - Baseline agent without tracing",
    "agent_v1.py - Agent with LangSmith tracing",
    "agent_v2.py - Enhanced tool instructions",
    "agent_v3.py - Stock information policy",
    "agent_v4.py - No-chunking RAG",
    "agent_v5.py - Conciseness improvements",
    "query_database - Tool for product inventory queries",
    "search_knowledge_base - Tool for company policy search",
    "schema_before_query - Evaluator for database schema checks",
    "eval_conciseness_pairwise - Pairwise conciseness evaluator",
    "run_experiment - Experiment runner for agent evaluation",
    "upload_traces - Trace upload utility for production"
  ]
